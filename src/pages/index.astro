---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 5);

const homeTitle = 'Ilyas Alhassan | AI Engineer — Production GenAI Systems';

const personJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'Person',
	name: 'Ilyas Alhassan',
	url: Astro.site?.href,
	jobTitle: 'AI Engineer',
	description: SITE_DESCRIPTION,
	sameAs: [
		'https://www.linkedin.com/in/ilyasalhassan/',
		'https://github.com/ilyas-hassan',
		'https://x.com/yasilhas',
	],
};
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={homeTitle} description={SITE_DESCRIPTION} />
		<script type="application/ld+json" set:html={JSON.stringify(personJsonLd)} is:inline />
	</head>
	<body>
		<Header />
		<main id="main-content">
			<section class="hero">
				<p class="eyebrow">Ilyas Alhassan — Minneapolis</p>
				<h1>I ship AI systems for a living.</h1>
				<p class="lede">
					I write about the gap between the demo and production —
					what works, what breaks, and what nobody warned me about.
				</p>
			</section>

			<section class="notes">
				<header class="section-header">
					<h2>Recent notes</h2>
					<a href="/blog" class="see-all">All posts →</a>
				</header>

				{posts.length === 0 ? (
					<p class="empty">No posts yet. First one coming soon.</p>
				) : (
					<ul class="post-list">
						{posts.map(post => (
							<li>
								<a href={`/blog/${post.id}/`} class="post-link no-underline">
									<div class="post-row">
										<span class="post-title">{post.data.title}</span>
										<span class="post-date meta">
											<FormattedDate date={post.data.pubDate} />
										</span>
									</div>
									{post.data.description && (
										<p class="post-description">{post.data.description}</p>
									)}
								</a>
							</li>
						))}
					</ul>
				)}
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		margin-bottom: var(--space-7);
	}

	.eyebrow {
		font-family: var(--font-mono);
		font-size: 0.85rem;
		color: var(--muted);
		text-transform: none;
		letter-spacing: 0.02em;
		margin-bottom: var(--space-2);
	}

	.hero h1 {
		font-size: 3rem;
		line-height: 1.05;
		letter-spacing: -0.03em;
		margin-bottom: var(--space-3);
		max-width: 14ch;
	}

	.lede {
		font-size: 1.25rem;
		line-height: 1.5;
		color: var(--muted);
		max-width: 52ch;
		margin: 0;
	}

	.notes {
		margin-top: var(--space-7);
	}

	.section-header {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		margin-bottom: var(--space-3);
		padding-bottom: var(--space-2);
		border-bottom: 1px solid var(--rule);
	}

	.section-header h2 {
		margin: 0;
		font-size: 0.95rem;
		font-weight: 600;
		font-family: var(--font-mono);
		color: var(--muted);
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.see-all {
		font-size: 0.9rem;
		font-weight: 500;
		color: var(--teal);
		border-bottom: none;
		font-family: var(--font-mono);
	}

	.see-all:hover {
		color: var(--orange);
	}

	.post-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.post-list li {
		border-bottom: 1px solid var(--rule);
	}

	.post-list li:last-child {
		border-bottom: none;
	}

	.post-link {
		display: block;
		padding: var(--space-3) 0;
		color: var(--ink);
		border-bottom: none;
		transition: transform 0.15s ease;
	}

	.post-link:hover {
		color: var(--ink);
	}

	.post-link:hover .post-title {
		color: var(--teal);
	}

	.post-row {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 1rem;
		margin-bottom: 0.35rem;
	}

	.post-title {
		font-family: var(--font-display);
		font-size: 1.2rem;
		font-weight: 600;
		color: var(--ink);
		letter-spacing: -0.01em;
		transition: color 0.15s ease;
	}

	.post-date {
		flex-shrink: 0;
		font-size: 0.8rem;
	}

	.post-description {
		font-size: 0.95rem;
		line-height: 1.55;
		color: var(--muted);
		margin: 0;
	}

	.empty {
		color: var(--muted);
		font-style: italic;
	}

	@media (max-width: 720px) {
		.hero h1 {
			font-size: 2.25rem;
			max-width: none;
		}

		.lede {
			font-size: 1.1rem;
		}

		.post-row {
			flex-direction: column;
			gap: 0.25rem;
			align-items: flex-start;
		}

		.post-title {
			font-size: 1.1rem;
		}
	}
</style>