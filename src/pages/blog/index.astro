---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Writing | ${SITE_TITLE}`} description="Writing by Ilyas Alhassan on shipping AI systems into production." />
	</head>
	<body>
		<Header />
		<main id="main-content">
			<section class="intro">
				<p class="eyebrow">Writing</p>
				<h1>Notes from production.</h1>
				<p class="lede">
					What works, what breaks, and what nobody warned me about.
				</p>
			</section>

			<section class="posts">
				{posts.length === 0 ? (
					<p class="empty">No posts yet. First one coming soon.</p>
				) : (
					<ul>
						{posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`} class="post-link no-underline">
									<div class="post-meta meta">
										<FormattedDate date={post.data.pubDate} />
									</div>
									<h2 class="post-title">{post.data.title}</h2>
									{post.data.description && (
										<p class="post-description">{post.data.description}</p>
									)}
								</a>
							</li>
						))}
					</ul>
				)}
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.intro {
		margin-bottom: var(--space-6);
	}

	.eyebrow {
		font-family: var(--font-mono);
		font-size: 0.85rem;
		color: var(--muted);
		letter-spacing: 0.02em;
		margin-bottom: var(--space-2);
	}

	.intro h1 {
		font-size: 2.75rem;
		line-height: 1.05;
		letter-spacing: -0.03em;
		margin-bottom: var(--space-3);
	}

	.lede {
		font-size: 1.25rem;
		line-height: 1.55;
		color: var(--muted);
		max-width: 52ch;
		margin: 0;
	}

	.posts ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.posts li {
		border-top: 1px solid var(--rule);
	}

	.posts li:last-child {
		border-bottom: 1px solid var(--rule);
	}

	.post-link {
		display: block;
		padding: var(--space-4) 0;
		color: var(--ink);
		border-bottom: none;
	}

	.post-link:hover {
		color: var(--ink);
	}

	.post-link:hover .post-title {
		color: var(--teal);
	}

	.post-meta {
		margin-bottom: 0.5rem;
	}

	.post-title {
		font-family: var(--font-display);
		font-size: 1.5rem;
		font-weight: 600;
		letter-spacing: -0.02em;
		line-height: 1.2;
		margin: 0 0 0.5rem 0;
		color: var(--ink);
		text-transform: none;
		padding-bottom: 0;
		border-bottom: none;
	}

	.post-description {
		font-size: 1rem;
		line-height: 1.6;
		color: var(--muted);
		margin: 0;
	}

	.empty {
		color: var(--muted);
		font-style: italic;
	}

	@media (max-width: 720px) {
		.intro h1 {
			font-size: 2.25rem;
		}

		.lede {
			font-size: 1.1rem;
		}

		.post-title {
			font-size: 1.25rem;
		}
	}
</style>