---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Writing | ${SITE_TITLE}`} description="Writing by Ilyas Alhassan on shipping AI systems into production." />
	</head>
	<body>
		<Header />
		<main>
			<section class="intro">
				<h1>Writing</h1>
				<p class="lede">
					Notes on shipping AI systems — what works, what breaks, and
					what nobody warned me about.
				</p>
			</section>

			<section class="posts">
				{posts.length === 0 ? (
					<p class="empty">No posts yet. Check back soon.</p>
				) : (
					<ul>
						{posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									<div class="post-meta">
										<FormattedDate date={post.data.pubDate} />
									</div>
									<h2 class="post-title">{post.data.title}</h2>
									{post.data.description && (
										<p class="post-description">{post.data.description}</p>
									)}
								</a>
							</li>
						))}
					</ul>
				)}
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 720px;
		margin: 0 auto;
		padding: 3rem 1rem;
	}
	.intro h1 {
		font-size: 2.25rem;
		margin-bottom: 1rem;
		line-height: 1.1;
	}
	.lede {
		font-size: 1.2rem;
		line-height: 1.6;
		color: rgb(var(--gray-dark));
		margin-bottom: 3rem;
	}
	.posts ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.posts li {
		margin-bottom: 2.5rem;
		padding-bottom: 2.5rem;
		border-bottom: 1px solid rgba(var(--gray), 0.2);
	}
	.posts li:last-child {
		border-bottom: none;
	}
	.posts a {
		text-decoration: none;
		display: block;
		color: inherit;
	}
	.post-meta {
		font-size: 0.9rem;
		color: rgb(var(--gray));
		margin-bottom: 0.5rem;
	}
	.post-title {
		font-size: 1.5rem;
		line-height: 1.3;
		margin: 0 0 0.75rem 0;
		color: rgb(var(--black));
	}
	.posts a:hover .post-title {
		color: rgb(var(--accent));
	}
	.post-description {
		font-size: 1rem;
		line-height: 1.6;
		color: rgb(var(--gray-dark));
		margin: 0;
	}
	.empty {
		font-size: 1.05rem;
		color: rgb(var(--gray));
		font-style: italic;
	}
</style>