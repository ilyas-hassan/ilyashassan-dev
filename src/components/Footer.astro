---
const today = new Date();
---

<footer>
	<div class="inner">
		<span class="copyright">© {today.getFullYear()} Ilyas Alhassan</span>
		<div class="links">
			<a href="mailto:hello@ilyashassan.dev" class="no-underline">Email</a>
			<a href="https://www.linkedin.com/in/ilyasalhassan/" target="_blank" rel="noopener noreferrer" class="no-underline">LinkedIn</a>
			<a href="https://github.com/ilyas-hassan" target="_blank" rel="noopener noreferrer" class="no-underline">GitHub</a>
			<a href="/rss.xml" class="no-underline">RSS</a>
		</div>
	</div>
</footer>

<style>
	footer {
		border-top: 1px solid var(--rule);
		background: var(--paper);
		margin-top: var(--space-7);
	}

	.inner {
		max-width: var(--content-width);
		margin: 0 auto;
		padding: 2rem 1.5rem;
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1rem;
	}

	.copyright {
		font-family: var(--font-mono);
		font-size: 0.85rem;
		color: var(--muted);
	}

	.links {
		display: flex;
		gap: 1.25rem;
	}

	.links a {
		font-size: 0.9rem;
		color: var(--muted);
		font-weight: 500;
		transition: color 0.15s ease;
	}

	.links a:hover {
		color: var(--ink);
	}

	@media (max-width: 720px) {
		.inner {
			flex-direction: column;
			align-items: flex-start;
			gap: 1rem;
			padding: 1.5rem 1.25rem;
		}

		.links {
			gap: 1rem;
			flex-wrap: wrap;
		}

		.links a {
			font-size: 0.85rem;
		}
	}
</style>