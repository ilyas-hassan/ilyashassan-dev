---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<a href="#main-content" class="skip-link">Skip to content</a>

<header>
	<nav>
		<a href="/" class="brand no-underline">{SITE_TITLE}</a>

		<div class="nav-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Notes</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>

		<div class="social-links">
			<a href="https://www.linkedin.com/in/ilyasalhassan/" target="_blank" rel="noopener noreferrer" class="no-underline" aria-label="LinkedIn">
				<svg viewBox="0 0 16 16" width="18" height="18" aria-hidden="true">
					<path fill="currentColor" d="M13.632 13.635h-2.37V9.922c0-.886-.018-2.025-1.234-2.025-1.235 0-1.424.964-1.424 1.96v3.778h-2.37V6h2.275v1.04h.032c.317-.6 1.091-1.233 2.246-1.233 2.4 0 2.845 1.58 2.845 3.637v4.191zM3.558 4.955a1.374 1.374 0 1 1 0-2.75 1.374 1.374 0 0 1 0 2.75zm1.188 8.68H2.37V6h2.376v7.635zM14.816 0H1.18C.528 0 0 .516 0 1.153v13.694C0 15.484.528 16 1.18 16h13.635c.652 0 1.185-.516 1.185-1.153V1.153C16 .516 15.467 0 14.815 0h.001z"></path>
				</svg>
			</a>
			<a href="https://x.com/yasilhas" target="_blank" rel="noopener noreferrer" class="no-underline" aria-label="X">
				<svg viewBox="0 0 16 16" width="18" height="18" aria-hidden="true">
					<path fill="currentColor" d="M5.026 15c6.038 0 9.341-5.003 9.341-9.334 0-.14 0-.282-.006-.422A6.685 6.685 0 0 0 16 3.542a6.658 6.658 0 0 1-1.889.518 3.301 3.301 0 0 0 1.447-1.817 6.533 6.533 0 0 1-2.087.793A3.286 3.286 0 0 0 7.875 6.03a9.325 9.325 0 0 1-6.767-3.429 3.289 3.289 0 0 0 1.018 4.382A3.323 3.323 0 0 1 .64 6.575v.045a3.288 3.288 0 0 0 2.632 3.218 3.203 3.203 0 0 1-.865.115 3.23 3.23 0 0 1-.614-.057 3.283 3.283 0 0 0 3.067 2.277A6.588 6.588 0 0 1 .78 13.58a6.32 6.32 0 0 1-.78-.045A9.344 9.344 0 0 0 5.026 15z"></path>
				</svg>
			</a>
			<a href="https://github.com/ilyas-hassan" target="_blank" rel="noopener noreferrer" class="no-underline" aria-label="GitHub">
				<svg viewBox="0 0 16 16" width="18" height="18" aria-hidden="true">
					<path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"></path>
				</svg>
			</a>
		</div>
	</nav>
</header>

<style>
	.skip-link {
		position: absolute;
		top: -100%;
		left: var(--space-2);
		z-index: 100;
		background: var(--teal);
		color: var(--paper);
		padding: 0.6rem 1rem;
		border-radius: 4px;
		font-family: var(--font-mono);
		font-size: 0.9rem;
		font-weight: 600;
		text-decoration: none;
		border-bottom: none;
		transition: top 0.15s ease;
	}

	.skip-link:focus {
		top: var(--space-2);
	}

	header {
		border-bottom: 1px solid var(--rule);
		background: var(--paper);
	}

	nav {
		max-width: var(--content-width);
		margin: 0 auto;
		padding: 1.25rem 1.5rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}

	.brand {
		font-family: var(--font-display);
		font-weight: 600;
		font-size: 1.05rem;
		color: var(--ink);
		letter-spacing: -0.01em;
	}

	.brand:hover {
		color: var(--teal);
	}

	.nav-links {
		display: flex;
		gap: 1.5rem;
		align-items: center;
	}

	.nav-links :global(a) {
		font-size: 0.95rem;
		color: var(--muted);
		font-weight: 500;
		border-bottom: none;
		padding: 0.25rem 0;
		transition: color 0.15s ease;
	}

	.nav-links :global(a:hover),
	.nav-links :global(a.active) {
		color: var(--ink);
	}

	.social-links {
		display: flex;
		gap: 0.75rem;
		align-items: center;
	}

	.social-links a {
		color: var(--muted);
		display: flex;
		align-items: center;
		transition: color 0.15s ease;
	}

	.social-links a:hover {
		color: var(--teal);
	}

	@media (max-width: 720px) {
		nav {
			padding: 1rem 1.25rem;
			flex-wrap: wrap;
			gap: 0.75rem;
		}

		.brand {
			font-size: 1rem;
		}

		.nav-links {
			gap: 1.25rem;
			order: 3;
			width: 100%;
			justify-content: flex-start;
			padding-top: 0.5rem;
			border-top: 1px solid var(--rule);
		}

		.nav-links :global(a) {
			font-size: 0.9rem;
		}

		.social-links {
			gap: 0.75rem;
		}
	}
</style>