---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';

type Props = CollectionEntry<'blog'>['data'] & { readingTime?: string };

const { title, description, pubDate, updatedDate, readingTime } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>

	<body>
		<Header />
		<main>
			<article>
				<header class="post-header">
					<div class="post-meta meta">
						<FormattedDate date={pubDate} />
						{readingTime && (
							<>
								<span class="dot">·</span>
								<span>{readingTime}</span>
							</>
						)}
						{updatedDate && (
							<>
								<span class="dot">·</span>
								<span>Updated <FormattedDate date={updatedDate} /></span>
							</>
						)}
					</div>
					<h1>{title}</h1>
					{description && <p class="post-lede">{description}</p>}
				</header>

				<div class="post-body">
					<slot />
				</div>

				<footer class="post-footer">
					<a href="/blog" class="back-link no-underline">← Back to writing</a>
				</footer>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	.post-header {
		margin-bottom: var(--space-5);
		padding-bottom: var(--space-3);
		border-bottom: 1px solid var(--rule);
	}

	.post-meta {
		margin-bottom: var(--space-2);
	}

	.post-header h1 {
		font-size: 2.5rem;
		line-height: 1.1;
		letter-spacing: -0.025em;
		margin-bottom: var(--space-2);
	}

	.post-lede {
		font-size: 1.2rem;
		line-height: 1.5;
		color: var(--muted);
		margin: 0;
		max-width: 52ch;
	}

	.post-body :global(p) {
		font-size: 1.0625rem;
		line-height: 1.8;
		margin-bottom: var(--space-3);
	}

	.post-body :global(h2) {
		font-size: 1.5rem;
		margin-top: var(--space-5);
		margin-bottom: var(--space-2);
		letter-spacing: -0.015em;
	}

	.post-body :global(h3) {
		font-size: 1.2rem;
		margin-top: var(--space-4);
		margin-bottom: var(--space-2);
	}

	.post-body :global(ul),
	.post-body :global(ol) {
		font-size: 1.0625rem;
		line-height: 1.8;
		padding-left: var(--space-3);
		margin-bottom: var(--space-3);
	}

	.post-body :global(li) {
		margin-bottom: 0.5rem;
	}

	.post-body :global(img) {
		max-width: 100%;
		height: auto;
		border-radius: 6px;
		margin: var(--space-3) 0;
	}

	.post-footer {
		margin-top: var(--space-6);
		padding-top: var(--space-3);
		border-top: 1px solid var(--rule);
	}

	.back-link {
		font-family: var(--font-mono);
		font-size: 0.9rem;
		color: var(--muted);
		border-bottom: none;
	}

	.back-link:hover {
		color: var(--teal);
	}

	@media (max-width: 720px) {
		.post-header h1 {
			font-size: 2rem;
		}

		.post-lede {
			font-size: 1.1rem;
		}

		.post-body :global(p) {
			font-size: 1rem;
		}
	}
</style>